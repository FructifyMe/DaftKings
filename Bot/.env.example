# DaftKings Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── ANTHROPIC (Claude Haiku) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── THE ODDS API ─────────────────────────────────────────────────────────────
# Get free key at: https://the-odds-api.com
# Free tier: 500 requests/month (enough for development)
ODDS_API_KEY=your_odds_api_key_here

# ─── KALSHI ───────────────────────────────────────────────────────────────────
# Create account at https://kalshi.com → Settings → API Keys
# For paper trading, use sandbox: https://demo-api.kalshi.co
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_private_key_pem_path_here

# ─── TELEGRAM ALERTS ──────────────────────────────────────────────────────────
# 1. Create bot: talk to @BotFather on Telegram → /newbot
# 2. Get your chat ID: talk to @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── BOT BEHAVIOR ─────────────────────────────────────────────────────────────
# PAPER_MODE: true = simulate only (safe). false = real money on Kalshi.
# DO NOT set false until paper testing is complete and Mike approves.
PAPER_MODE=true

# Starting bankroll for Kelly sizing calculations (USD)
STARTING_BANKROLL=1000

# Kelly fraction (0.25 = Quarter Kelly — recommended for all phases)
KELLY_FRACTION=0.25

# Max bets per day (quality filter)
MAX_DAILY_BETS=3

# Minimum estimated edge to consider a bet (5% = 0.05)
MIN_EDGE_THRESHOLD=0.05

# Kill switch: halt betting if daily drawdown exceeds this % (40% = 0.40)
KILL_SWITCH_DRAWDOWN=0.40

# Max % of bankroll on any single bet (5% = 0.05)
MAX_BET_PCT=0.05
